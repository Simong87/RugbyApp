import Ruvby_database

MENU_PROMPT = """ RUGBY PLAYER DATABASE

Please choose one of these options:
1. Add new player
2. See all players
3. Find player by name
4. See highest-rated performance for player
5. Exit.

Your selection: """

def menu():
    connection = Ruvby_database.connect()
    Ruvby_database.create_tables(connection)

    while (user_input := input(MENU_PROMPT)) != "5":
        if user_input == "1":
            prompt_add_new_player(connection)
        elif user_input == "2":
            prompt_see_all_players(connection)
        elif user_input == "3":
            prompt_find_player(connection)
        elif user_input == "4":
            prompt_find_best_player(connection)
        else:
            print("Invalid input, please try again.")

def prompt_add_new_player(connection):
    name = input("Enter player name: ")
    position = input("Enter player position (e.g., Scrum-half, Wing): ")
    rating = int(input("Enter performance rating (1–100): "))
    Ruvby_database.add_player(connection, name, position, rating)

def prompt_see_all_players(connection):
    players = Ruvby_database.get_all_players(connection)

    for player in players:
        print(f"{player[1]} ({player[2]}) - {player[3]}/100")

def prompt_find_player(connection):
    name = input("Enter player name to find: ")
    players = Ruvby_database.get_players_by_name(connection, name)

    for player in players:
        print(f"{player[1]} ({player[2]}) - {player[3]}/100")

def prompt_find_best_player(connection):
    name = input("Enter player name: ")
    best_player = Ruvby_database.get_best_player(connection, name)

    if best_player:
        print(f"Best performance for {name}: {best_player[2]} position with rating {best_player[3]}/100")
    else:
        print("Player not found.")

menu()
